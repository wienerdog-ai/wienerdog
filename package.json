{
  "name": "wienerdog",
  "version": "0.10.0",
  "description": "Give your AI a memory, habits, and a daily routine — with nothing but files. One-line setup for Claude Code and Codex CLI.",
  "license": "MIT",
  "bin": {
    "wienerdog": "bin/wienerdog.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "templates/"
  ],
  "dependencies": {
    "googleapis": "^173.0.0"
  },
  "scripts": {
    "test": "node tests/run.js",
    "lint": "node scripts/lint.js",
    "gen:agents": "node scripts/gen-agents-md.js",
    "scenarios": "node tests/scenarios/run-scenarios.js",
    "scenarios:negative": "node tests/scenarios/negative/run-negative.js",
    "broker:selfcheck": "node tests/scenarios/broker/lifecycle-selfcheck.js",
    "scenarios:broker-e2e": "node tests/scenarios/broker-e2e/run-broker-e2e.js",
    "scenarios:a7-integrity": "node tests/scenarios/a7-integrity/run-a7-integrity.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wienerdog-ai/wienerdog.git"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai-memory",
    "second-brain",
    "agents-md",
    "claude-md",
    "skills"
  ],
  "devDependencies": {
    "markdownlint-cli2": "^0.23.0"
  },
  "markdownlint-cli2": {
    "config": {
      "default": true,
      "MD009": false,
      "MD013": false,
      "MD022": false,
      "MD025": false,
      "MD031": false,
      "MD032": false,
      "MD033": false,
      "MD034": false,
      "MD040": false,
      "MD060": false,
      "MD024": {
        "siblings_only": true
      }
    }
  }
}
